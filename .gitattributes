# Treat binary files as binary (no line ending conversion)
*.pdf binary
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary

# Ensure consistent line endings for content files
*.mdx text eol=lf
*.md text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
